# Copy to .env and fill in. Used by docker-compose.yml.

# Shared secret between the Xenia-WebServices /logs proxy (its LOG_BACKEND_TOKEN) and this backend.
INGEST_TOKEN=change-me

# Grafana first-boot admin login.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# Grafana URL used to build the OPERATOR-facing deep-link the ingest logs per report 
# Set to your real Grafana URL so the logged links are clickable for you.
GRAFANA_BASE_URL=http://localhost/grafana

# Hostname for nginx proxy to grafana, loki, and the ingest endpoint
HOSTNAME=localhost