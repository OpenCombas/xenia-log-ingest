# Example htpasswd for the /loki/ basic_auth. DO NOT use this line as-is — generate your own:
#   htpasswd -cB nginx/loki.htpasswd promtail          # bcrypt, prompts for the password
# (add more users by dropping -c). The real nginx/loki.htpasswd is gitignored.
#
# IMPORTANT: create nginx/loki.htpasswd BEFORE `docker compose up` — the compose bind-mount will
# otherwise create it as a directory and nginx will fail to start.
#
# Format is <user>:<bcrypt-hash>, e.g.:
promtail:$2y$05$e0Nq0000000000000000000000000000000000000000000000000
